{
  "name": "@namphuongtechnologi/np-hub",
  "version": "0.2.4",
  "description": "NP Hub Web Component toolkit for support flows.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./widget": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.ts"
      ],
      "widget": [
        "./dist/register.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "react.d.ts",
    "react.js",
    "react.cjs",
    "widget.d.ts",
    "widget.js",
    "widget.cjs",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && node scripts/postbuild-shims.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:module-resolution": "npm run build && cd tests/module-resolution-node && npm init -y >/dev/null 2>&1 && npm install ../../ >/dev/null 2>&1 && npx tsc --noEmit",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "web-component",
    "np-hub",
    "support-widget",
    "sdk",
    "custom-element"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/react": "^18.3.23",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "react": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
